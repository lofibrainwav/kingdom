{
  "name": "kingdom",
  "version": "1.0.0",
  "description": "Kingdom - real-world agent operating system for planning, execution, knowledge, and governance",
  "main": "index.js",
  "scripts": {
    "test": "node --test --test-force-exit --test-concurrency=1 test/*.test.js",
    "test:blackboard": "node --test --test-force-exit test/blackboard.test.js",
    "start": "node --env-file=.env agent/interface/dashboard.js",
    "start:pipeline": "node --env-file=.env agent/team/pm-agent.js",
    "seed:skills": "node --env-file=.env scripts/seed-skills.js",
    "e2e": "node --env-file=.env scripts/e2e-pipeline.js",
    "memory": "node scripts/auto-memory.js",
    "memory:operator": "node --env-file=.env scripts/run-knowledge-operator.js",
    "memory:notebooklm-queue": "node --env-file=.env scripts/run-notebooklm-promotion-queue.js",
    "memory:notebooklm-prepare": "node --env-file=.env scripts/run-notebooklm-packet-queue.js",
    "memory:notebooklm-ingest": "node --env-file=.env scripts/run-notebooklm-ingestion-queue.js",
    "skills:eval": "node scripts/run-skill-evals.js",
    "compound": "node --env-file=.env scripts/compound-demo.js",
    "party": "node --env-file=.env scripts/party-mode.js",
    "redis:check": "redis-cli -p 6380 ping",
    "lint": "eslint agent/ test/",
    "status": "redis-cli hgetall kingdom:team:status:latest 2>/dev/null || echo \"Redis key not set yet\"",
    "sync": "node scripts/sync-to-vault.js",
    "sync:quick": "node scripts/sync-to-vault.js --quick",
    "sync:review": "node scripts/sync-to-vault.js --review",
    "vault:health": "node scripts/vault-health.js",
    "vault:seed": "node scripts/seed-zettelkasten.js",
    "vault:digest": "node scripts/vault-digest.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "discord.js": "^14.25.1",
    "groq-sdk": "^0.37.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1"
  },
  "//overrides": "undici pinned to 6.23.0 — discord.js transitive dep; later versions have breaking fetch changes",
  "overrides": {
    "undici": "6.23.0"
  }
}
