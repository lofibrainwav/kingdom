# ─────────────────────────────────────────────────────────────
# Octiv MVP — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# NEVER commit real values. Copy to .env and fill in.
#   cp .env.example .env
#
# For secrets management, prefer:
#   op run -- npm start          (1Password CLI)
#   doppler run -- npm start     (Doppler)
#   infisical run -- npm start   (Infisical)
#
# Rotate all tokens every 60-90 days.
# ─────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
# Options: development | staging | production

# ── Minecraft / PaperMC — [REMOVED: Minecraft 전환 완료]
# (Vibe Coding 아키텍쳐로 전환됨. Minecraft 스택 불필요)


# ── Redis (Blackboard) ──────────────────────────────────────
BLACKBOARD_REDIS_URL=redis://localhost:6380

# ── Discord Bot ──────────────────────────────────────────
# Discord Developer Portal: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=          # ⚠️ 필수: Bot Token
DISCORD_CHANNEL_ID=         # ⚠️ 필수: 기본 담당 채널 ID
DISCORD_GUILD_ID=

# ── Obsidian Vault ─────────────────────────────────────────
# 예: /Users/yourname/Documents/ObsidianVault
OBSIDIAN_VAULT=             # ⚠️ 필수: Vault 절대 경로

# ── MCP: GitHub ──────────────────────────────────────────────
# Use fine-grained PAT scoped to octivofficial/mvp only
# Required scopes: contents:read, issues:write, pull_requests:write
GITHUB_TOKEN=

# ── MCP: Supabase ────────────────────────────────────────────
# Dev and Prod use separate project refs + tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Production overrides (only used when NODE_ENV=production)
SUPABASE_PROD_ACCESS_TOKEN=
SUPABASE_PROD_PROJECT_REF=

# ── MCP: Vercel ──────────────────────────────────────────────
# Scoped to octiv team only
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ── MCP: Sentry ──────────────────────────────────────────────
# org-level auth token with project:read, event:read scopes
SENTRY_AUTH_TOKEN=
SENTRY_ORG=octiv
SENTRY_PROJECT=octiv-mvp

# ── MCP: Figma ───────────────────────────────────────────────
# Read-only personal access token
FIGMA_ACCESS_TOKEN=

# ── LLM (ReflexionEngine) ───────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Services ────────────────────────────────
DASHBOARD_PORT=3000
MCP_PORT=3001
MC_VERSION=1.21.1

# ── Logging ──────────────────────────────────
# LOG_LEVEL=info
# Options: debug | info | warn | error

# ── Timeouts & Limits ──────────────────────
# SPAWN_TIMEOUT_MS=30000
# PATHFINDER_TIMEOUT_MS=30000
# HEARTBEAT_INTERVAL_MS=10000
# SKILL_DAILY_LIMIT=5
# SKILL_MIN_SUCCESS_RATE=0.7
# VM_TIMEOUT_MS=3000

# ── Safety & Emergency ────────────────────
# SAFETY_THREAT_COOLDOWN_MS=2000
# EMERGENCY_DEDUP_MS=3000
# SPAWN_GROUND_WAIT_MS=2000
