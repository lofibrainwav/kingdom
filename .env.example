# ─────────────────────────────────────────────────────────────
# Kingdom MVP — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# NEVER commit real values. Copy to .env and fill in.
#   cp .env.example .env
#
# For secrets management, prefer:
#   op run -- npm start          (1Password CLI)
#   doppler run -- npm start     (Doppler)
#   infisical run -- npm start   (Infisical)
#
# Rotate all tokens every 60-90 days.
# ─────────────────────────────────────────────────────────────

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development
# Options: development | staging | production

# ── Minecraft / PaperMC (optional, legacy adapter) ─────────
# MC_HOST=localhost
# MC_PORT=25565
# RCON_HOST=localhost
# RCON_PORT=25575
# RCON_PASSWORD=

# ── Redis (Blackboard) ──────────────────────────────────────
BLACKBOARD_REDIS_URL=redis://localhost:6380

# ── Discord Bot ──────────────────────────────────────────
# Discord Developer Portal: https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STATUS_CHANNEL=
DISCORD_ALERTS_CHANNEL=
DISCORD_COMMANDS_CHANNEL=
DISCORD_CHAT_CHANNEL=
DISCORD_FORUM_CHANNEL=

# ── Obsidian Vault ─────────────────────────────────────────
# 예: /Users/yourname/Documents/ObsidianVault
OBSIDIAN_VAULT=             # ⚠️ 필수: Vault 절대 경로

# ── MCP: GitHub ──────────────────────────────────────────────
# Use fine-grained PAT scoped to lofibrainwav/kingdom only
# Required scopes: contents:read, issues:write, pull_requests:write
GITHUB_TOKEN=

# ── MCP: Supabase ────────────────────────────────────────────
# Dev and Prod use separate project refs + tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Production overrides (only used when NODE_ENV=production)
SUPABASE_PROD_ACCESS_TOKEN=
SUPABASE_PROD_PROJECT_REF=

# ── MCP: Vercel ──────────────────────────────────────────────
# Scoped to kingdom team only
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ── MCP: Sentry ──────────────────────────────────────────────
# org-level auth token with project:read, event:read scopes
SENTRY_AUTH_TOKEN=
SENTRY_ORG=kingdom
SENTRY_PROJECT=kingdom-mvp

# ── MCP: Figma ───────────────────────────────────────────────
# Read-only personal access token
FIGMA_ACCESS_TOKEN=

# ── LLM (ReflexionEngine) ───────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=
LM_STUDIO_URL=
# LM_STUDIO_ENABLED=false    # Set to 'false' to disable; any other value (or unset) enables LM Studio
LLM_PRIMARY_MODEL=

# ── Services ────────────────────────────────
DASHBOARD_PORT=3000

# ── Logging ──────────────────────────────────
# LOG_LEVEL=info
# Options: debug | info | warn | error

# ── Timeouts & Limits ──────────────────────
# VM_TIMEOUT_MS=3000

# ── Skill System ─────────────────────────
# SKILL_DAILY_LIMIT=5             # Max auto-generated skills per day
# SKILL_MIN_SUCCESS_RATE=0.7      # Minimum success rate before skill discard

# ── Testing ──────────────────────────────
# TEST_SWARM_MAIN=1               # Enable swarm-orchestrator main entry for tests
